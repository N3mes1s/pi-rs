{
  "model": "gpt-5.4",
  "input": [
    {
      "role": "user",
      "content": [
        { "type": "input_text", "text": "hi" }
      ]
    }
  ],
  "stream": true,
  "store": false,
  "max_output_tokens": 256,
  "tools": [
    {
      "type": "function",
      "name": "echo_tool",
      "description": "Echo a message back.",
      "parameters": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        },
        "required": ["message"]
      },
      "strict": true
    }
  ],
  "reasoning": {
    "effort": "medium",
    "summary": "auto"
  },
  "include": ["reasoning.encrypted_content"]
}
